{
  "name": "@toon-protocol/swap",
  "version": "0.1.0",
  "description": "TOON Protocol swap node — multi-chain payment-channel claim issuer (EVM/Solana/Mina)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "toon-swap": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:anvil": "vitest run --config vitest.integration.config.ts tests/integration/swap-flow-anvil.integration.test.ts",
    "test:e2e:docker": "vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [
    "toon",
    "nostr",
    "ilp",
    "swap",
    "payment-channel"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/swap.git",
    "directory": "packages/swap"
  },
  "author": "ALLiDoizCode",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "@toon-protocol/connector": "^3.10.0",
    "@toon-protocol/core": "^1.4.1",
    "@toon-protocol/sdk": "^0.5.0",
    "ed25519-hd-key": "^1.3.0",
    "hono": "^4.11.10",
    "nostr-tools": "^2.20.0"
  },
  "peerDependencies": {
    "mina-signer": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "mina-signer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
